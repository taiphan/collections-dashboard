# =============================================================================
# Low-Code Platform — environment variables
# =============================================================================
# Copy this file to `.env.local` for development or `.env.production` for prod.

# ----- Runtime mode --------------------------------------------------------
NODE_ENV=development

# ----- Database (Postgres 16) ---------------------------------------------
# docker-compose.yml provisions Postgres on port 5432 in dev.
DATABASE_URL=postgres://lcp:lcp@localhost:5432/lcp

# ----- Auth (NextAuth v5) -------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-a-long-random-string
AUTH_URL=http://localhost:3020

# ----- Tenant resolution --------------------------------------------------
# In production, tenants are resolved from subdomain only.
# In dev, the X-Tenant-Id header is also accepted.
PLATFORM_ROOT_DOMAIN=lcp.localhost

# ----- Email (dev: MailHog; prod: Resend) ---------------------------------
EMAIL_TRANSPORT=smtp
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@lcp.localhost
# RESEND_API_KEY=

# ----- Object storage for attachments -------------------------------------
# `local-fs` writes to ./storage-local/ — for dev only.
STORAGE_DRIVER=local-fs
STORAGE_LOCAL_PATH=./storage-local
# S3 settings (used when STORAGE_DRIVER=s3)
# S3_ENDPOINT=
# S3_REGION=
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# ----- Limits --------------------------------------------------------------
ATTACHMENT_MAX_BYTES=20971520
ATTACHMENT_ALLOWED_TYPES=image/png,image/jpeg,image/gif,application/pdf,text/plain,text/csv,application/zip
